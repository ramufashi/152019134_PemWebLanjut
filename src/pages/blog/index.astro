---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getCollection("blog");
console.log("POSTS:", posts.length);

posts.sort(
  (a, b) =>
    b.data.pubDate.valueOf() -
    a.data.pubDate.valueOf()
);
---

<MainLayout title="Blog">
  <div class="container">
    <h1>Blog</h1>

    <ul class="blog-grid">
      {
        posts.map((post) => (
          <li class="card">
            <a href={`/blog/${post.id}`}>
              {
                post.data.heroImage && (
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="thumbnail"
                  />
                )
              }

              <h2 class="title">{post.data.title}</h2>

              <p class="date">
                {post.data.pubDate.toLocaleDateString()}
              </p>

              <p class="description">
                {post.data.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</MainLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }
  
  h1 {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--primary);
  }

  .blog-grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 2rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.card {
  width: 100%;
}

/* Featured latest post */
.card:first-child {
  grid-column: 1 / -1;
}

.card:first-child .thumbnail {
  height: 400px;
}

.card:first-child .title {
  font-size: 2rem;
}

@media (max-width: 768px) {
  .blog-grid {
    grid-template-columns: 1fr;
  }

  .card:first-child {
    grid-column: auto;
  }

  .card:first-child .thumbnail {
    height: 220px;
  }

  .card:first-child .title {
    font-size: 1.5rem;
  }
}

  .card {
    width: calc(50% - 1rem);
  }

  .card a {
    display: block;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    transition: transform 0.2s ease,
                box-shadow 0.2s ease;
  }

  .card a:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.12);
  }

  .thumbnail {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  .title {
    padding: 1rem 1rem 0.5rem;
    color: var(--primary);
    margin: 0;
  }

  .date {
    padding: 0 1rem;
    color: gray;
    font-size: 0.9rem;
  }

  .description {
    padding: 0.5rem 1rem 1rem;
    color: var(--text);
  }

  .card:first-child {
    width: 100%;
  }

  .card:first-child .thumbnail {
    height: 400px;
  }

  .card:first-child .title {
    font-size: 2rem;
  }

  @media (max-width: 768px) {
    .card,
    .card:first-child {
      width: 100%;
    }

    .card:first-child .title {
      font-size: 1.5rem;
    }

    .thumbnail,
    .card:first-child .thumbnail {
      height: 220px;
    }
  }
</style>