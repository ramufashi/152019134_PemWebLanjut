---
import heroImage from "../assets/header.jpg";
import MainLayout from "../layouts/MainLayout.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BPR Mangun Pundiyasa</title>

    <style>
      :root {
        --primary: #0f4c81;
        --secondary: #f5f7fa;
        --accent: #d9e8f5;
        --text: #1f2937;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        color: var(--text);
        background: white;
        line-height: 1.6;
      }

      header {
        background: var(--primary);
        color: white;
        padding: 1rem 2rem;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        <!--display: flex;-->
        align-items: center;
        gap: 0.8rem;
      }

      .logo img {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
      }

      .nav-links {
        display: flex;
        gap: 1.5rem;
      }

      .nav-links a {
        color: white;
        text-decoration: none;
        font-weight: bold;
      }

	.hero {
		  color: white;
		  text-align: center;
		  padding: 7rem 2rem;
	}

	.hero h1 {
		font-size: 3rem;
        margin-bottom: 1rem;
      }

	.hero-actions {
	  margin-top: 2rem;
	  display: flex;
	  justify-content: center;
	  gap: 1rem;
	}

	.btn {
	  position: relative;
	  overflow: hidden;
	  display: inline-block;
	  padding: 0.9rem 1.5rem;
	  border-radius: 8px;
	  text-decoration: none;
	  font-weight: bold;
	  transition:
		transform 0.25s ease,
		box-shadow 0.25s ease,
		opacity 0.25s ease;
	}

	.btn::before {
	  content: "";
	  position: absolute;
	  top: 0;
	  left: -120%;
	  width: 60%;
	  height: 100%;
	  background: rgba(255, 255, 255, 0.3);
	  filter: blur(10px);
	  transform: rotate(20deg);
	  transform: skewX(-25deg);
	  transition: left 0.6s ease;
	}

	.btn:hover::before {
	  left: 140%;
	}

	.btn-primary {
	  background: white;
	  color: var(--primary);
	}

	.btn-secondary {
	  background: transparent;
	  color: white;
	  border: 2px solid white;
	}

	.btn:hover {
	  transform: translateY(-4px) scale(1.03);
	  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
	}

	.btn:active {
	  transform: translateY(-1px);
	}

	.hero p {
		max-width: 700px;
        margin: auto;
        font-size: 1.1rem;
     }

  .services {
	padding: 4rem 2rem;
	background: var(--secondary);
  }

  .services h2 {
	text-align: center;
	margin-bottom: 2rem;
  }

	.service-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
		max-width: 1100px;
		margin: auto;
	}

      .card {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
      }

      .card h3 {
        margin-bottom: 1rem;
        color: var(--primary);
      }

      .about {
        padding: 4rem 2rem;
        max-width: 1000px;
        margin: auto;
        text-align: center;
      }

      .contact {
        background: var(--accent);
        padding: 4rem 2rem;
        text-align: center;
      }

      footer {
        background: var(--primary);
        color: white;
        text-align: center;
        padding: 1rem;
      }

      @media (max-width: 768px) {
        nav {
          flex-direction: column;
          gap: 1rem;
        }

        .hero h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>
  
<MainLayout title="Layanan BPR">
  <body>
    
    <section
	  class="hero"
	  style={`background:
		linear-gradient(
		  rgba(15, 76, 129, 0.7),
		  rgba(15, 76, 129, 0.7)
		),
		url(${heroImage.src}) center/cover;`}
	>
      <h1>BPR Mangun Pundiyasa</h1>
      <h2>
        Solusi Kebutuhan Anda
      </h2>
	  <div class="hero-actions">
	  <a href="/services" class="btn btn-primary">
		Lihat Layanan
	  </a>

	  <a href="/contact" class="btn btn-secondary">
		Hubungi Kami
	  </a>
	</div>
    </section>
	
	

    <section class="services">
      <h2>Layanan Kami</h2>

      <div class="service-grid">
        <div class="card">
          <h3>💰 Deposito</h3>
          <p>
            Menerima penyimpanan deposito dengan tenor 1 sampai 24 bulan dengan bunga hingga 6,75%
          </p>
        </div>

        <div class="card">
          <h3>🏦 Pinjaman</h3>
          <p>
            Menyediakan layanan pinjaman dana dengan plafon yang fleksibel
          </p>
        </div>
      </div>
    </section>

    <section class="about">
    <h2>Tentang Kami</h2>
	<h3><br>Visi</h3>
      <p>
        Menjadi bank yang terpercaya dalam menjalin kemitraan dengan dunia usaha untuk mendukung perekonomian Indonesia yang mandiri.
      </p>
	<h3><br>Misi</h3>
      <p>
        Memberikan pelayanan yang maksimal kepada pelanggan, menjangkau segenap lapisan masyarakat dengan memanfaatkan jaringan mitra melalui sebuah kerjasama yang saling menguntungkan, dan meningkatkan asset, kredit, dan simpanan yang signifikan.

      </p>
    </section>
	
	<section class="contact">
	  <h2>Hubungi Kami</h2>

	  <div class="contact-grid">
		<div>
		  <strong><br>📍 Alamat</strong>
		  <p>Jl Jend. Ahmad Yani no. 221 Kav 15-E, Ruko Segitiga Mas</p>
		</div>

		<div>
		  <strong>☎ Telepon</strong>
		  <p>022-7231010</p>
		</div>
	  </div>
	</section>
  </body>
</html>