        <div class="card">
          <h3>Tenor 36 Bulan</h3>
          <p><strong>Plafond Rp. 5 jt</strong>: Rp. 248.888</p>
          <p><strong>Plafond Rp. 8 jt</strong>: Rp. 398.222</p>
          <p><strong>Plafond Rp. 10 jt</strong>: Rp. 497.778</p>
